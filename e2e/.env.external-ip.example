# 외부 IP 접속 설정
# 복사 후 실제 값으로 교체: cp .env.external-ip.example .env.external-ip
EXTERNAL_IP=<서버_IP>
EXTERNAL_PORT=3001
EXTERNAL_HTTPS=false

# 사용자 자격증명
ADMIN_ID=<admin_아이디>
ADMIN_PASSWORD=<admin_비밀번호>

# 워크스페이스/프로젝트
WORKSPACE_NAME=ws01
PROJECT_NAME=default

# 선택: 설정 시 MCI 목록 자동 발견 없이 이 MCI만 사용
# MCI_ID=<mci_id>
